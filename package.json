{
  "name": "istasyon-takip-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Phase 1 backend for EV station management",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "doctor": "node scripts/doctor.mjs",
    "dev": "tsx watch src/server.ts",
    "dev:backend": "npm run dev",
    "dev:admin": "npm --prefix admin-web run dev -- --port 3001",
    "dev:mobile": "npm --prefix MobileApp run start",
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:integration",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "check": "npm run check:backend && npm run check:admin && npm run check:mobile",
    "check:backend": "npm run build",
    "check:admin": "npm --prefix admin-web run check",
    "check:mobile": "npm --prefix MobileApp run typecheck",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:migrate && npm run seed",
    "demo:reset": "npm run db:setup"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@sinclair/typebox": "^0.34.41",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
